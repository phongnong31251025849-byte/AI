import folium
from geopy.geocoders import Nominatim
from geopy.distance import geodesic
places = [
    "Chợ Bến Thành, Quận 1, Hồ Chí Minh",
    "Dinh Độc Lập, Quận 1, Hồ Chí Minh",
    "Nhà thờ Đức Bà Sài Gòn, Quận 1, Hồ Chí Minh",
    "Bảo tàng Chứng tích Chiến tranh, Quận 3, Hồ Chí Minh",
    "Tòa nhà Bitexco, Quận 1, Hồ Chí Minh",
    "Nhà hát Thành phố, Quận 1, Hồ Chí Minh",
    "Phố đi bộ Nguyễn Huệ, Quận 1, Hồ Chí Minh",
    "Công viên Tao Đàn, Quận 1, Hồ Chí Minh",
    "Landmark 81, Bình Thạnh, Hồ Chí Minh"
]
geolocator = Nominatim(user_agent="map_app")
locations = []
for p in places:
    loc = geolocator.geocode(p)
    if loc:
        locations.append((p, (loc.latitude, loc.longitude)))
center_name, center_coord = locations[0]
m = folium.Map(location=center_coord, zoom_start=14)
folium.Marker(
    location=center_coord,
    popup=f"Trung tâm: {center_name}",
    icon=folium.Icon(color="red")
).add_to(m)
for name, coord in locations:
    d = geodesic(center_coord, coord).km
    folium.Marker(
        location=coord,
        popup=f"{name}<br>{d:.2f} km"
    ).add_to(m)
m  
